{
    "name": "rbac-system",
    "version": "1.0.0",
    "description": "Production-grade RBAC system",
    "main": "dist/functionsEntry.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "seed": "ts-node src/scripts/seedRootOwner.ts",
        "cleanup": "ts-node src/scripts/cleanupPending.ts",
        "migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql"
    },
    "dependencies": {
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "firebase-admin": "^11.11.1",
        "firebase-functions": "^7.0.3",
        "pg": "^8.11.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.5",
        "@types/pg": "^8.10.9",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
