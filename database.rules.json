{
    "rules": {
        "attendance": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile/role').val() === 'md' || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner' || root.child('employees').child(auth.uid).child('profile/role').val() === 'hr')",
            ".write": false,
            "$date": {
                "$uid": {
                    ".read": "auth != null && auth.uid === $uid",
                    ".indexOn": [
                        "status"
                    ]
                }
            }
        },
        "users": {
            "$uid": {
                ".read": "auth != null && auth.uid === $uid",
                ".write": false
            }
        },
        "employees": {
            ".read": "auth != null",
            ".indexOn": [
                "profile/email"
            ],
            "$uid": {
                ".read": "auth != null && (auth.uid === $uid || root.child('employees').child(auth.uid).child('profile/role').val() === 'md' || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner')",
                ".write": "auth != null && (auth.uid === $uid || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner')",
                ".validate": "root.child('employees').child(auth.uid).child('profile/role').val() === 'owner' || newData.child('profile/role').val() === 'employee'",
                "profile": {
                    ".read": "auth != null"
                },
                "leaveBalance": {
                    ".read": "auth != null && (auth.uid === $uid || root.child('employees').child(auth.uid).child('profile/role').val() === 'md')",
                    ".write": "auth != null && (root.child('employees').child(auth.uid).child('profile/role').val() === 'md' || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner')"
                }
            }
        },
        "leaves": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile/role').val() === 'md' || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner')",
            ".indexOn": [
                "uid"
            ],
            "$uid": {
                ".read": "auth != null && auth.uid === $uid",
                ".write": "auth != null && (auth.uid === $uid || root.child('employees').child(auth.uid).child('profile/role').val() === 'md' || root.child('employees').child(auth.uid).child('profile/role').val() === 'owner')"
            }
        }
    }
}