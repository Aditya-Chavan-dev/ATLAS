{
    "rules": {
        ".read": false,
        ".write": false,
        "employees": {
            ".read": "auth != null",
            ".indexOn": [
                "email",
                "phone",
                "role"
            ],
            "$uid": {
                "profile": {
                    ".read": "auth != null && ($uid === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
                    ".write": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
                },
                "attendance": {
                    ".read": "auth != null && ($uid === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
                    "$date": {
                        ".write": "auth != null && ( (!data.exists() && $uid === auth.uid) || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' )"
                    }
                },
                ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' || $uid === auth.uid)",
                ".write": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
            }
        },
        "users": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
            ".write": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
        },
        "attendance": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
            ".write": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
        },
        "leaves": {
            "$employeeId": {
                ".read": "auth != null && ($employeeId === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
                "$leaveId": {
                    ".write": "auth != null && ((!data.exists() && $employeeId === auth.uid) || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
                }
            }
        },
        "audit": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
            "$logId": {
                ".write": "auth != null && (newData.child('actorUid').val() === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
            }
        },
        "deviceTokens": {
            "$token": {
                ".read": "auth != null && ((data.child('uid').val() === auth.uid) || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
                ".write": "auth != null && (newData.child('uid').val() === auth.uid)"
            }
        },
        "demo": {
            ".read": false,
            ".write": false,
            "sources": {
                ".indexOn": [
                    "createdAt",
                    "name"
                ],
                ".read": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'",
                "$sourceId": {
                    ".write": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'"
                }
            },
            "sessions": {
                ".indexOn": [
                    "sourceId",
                    "createdAt",
                    "completed"
                ],
                ".read": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'",
                "$sessionId": {
                    ".validate": "newData.hasChildren(['ownerUid', 'createdAt'])",
                    ".write": "auth != null && (!data.exists() || data.child('ownerUid').val() === auth.uid)",
                    "ownerUid": {
                        ".validate": "newData.val() === auth.uid"
                    },
                    "events": {
                        "$eventType": {
                            ".write": "auth != null && root.child('demo').child('sessions').child($sessionId).child('ownerUid').val() === auth.uid"
                        }
                    },
                    "completed": {
                        ".write": "auth != null && root.child('demo').child('sessions').child($sessionId).child('ownerUid').val() === auth.uid"
                    }
                }
            }
        }
    }
}