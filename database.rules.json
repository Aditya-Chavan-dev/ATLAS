{
    "rules": {
        ".read": false,
        ".write": false,
        "employees": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'hr')",
            ".indexOn": [
                "email",
                "phone",
                "role",
                "profile/email"
            ],
            "$uid": {
                ".read": "auth != null && ($uid === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'hr')",
                "profile": {
                    "role": {
                        ".validate": "newData.isString() && (newData.val() === 'owner' || newData.val() === 'md' || newData.val() === 'hr' || newData.val() === 'employee' || newData.val() === 'manager')"
                    },
                    "email": {
                        ".validate": "newData.isString()"
                    },
                    "status": {
                        ".validate": "newData.isString()"
                    },
                    ".read": "auth != null",
                    ".write": "auth != null"
                },
                "attendance": {
                    ".read": "auth != null && ($uid === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'hr')",
                    "$date": {
                        ".validate": "newData.hasChildren(['status', 'timestamp'])",
                        "status": {
                            ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'pending_co' || newData.val() === 'approved' || newData.val() === 'rejected' || newData.val() === 'correction_pending')"
                        },
                        "timestamp": {
                            ".validate": "newData.isString()"
                        },
                        ".write": "auth != null && ( root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'hr' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner' )"
                    }
                }
            }
        },
        "users": {
            ".read": false,
            ".write": false
        },
        "attendance": {
            ".read": false,
            ".write": false
        },
        "leaves": {
            "$employeeId": {
                ".read": "auth != null && ($employeeId === auth.uid || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
                "$leaveId": {
                    ".validate": "newData.hasChildren(['type', 'totalDays', 'status'])",
                    "type": {
                        ".validate": "newData.val() === 'PL' || newData.val() === 'CO' || newData.val() === 'SL'"
                    },
                    "totalDays": {
                        ".validate": "newData.isNumber()"
                    },
                    "status": {
                        ".validate": "newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected' || newData.val() === 'cancelled'"
                    },
                    ".write": "auth != null && ((!data.exists() && $employeeId === auth.uid && root.child('employees').child(auth.uid).child('profile').child('status').val() === 'ACTIVE') || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')"
                }
            }
        },
        "system": {
            "owners": {
                ".read": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'",
                ".write": "false"
            }
        },
        "audit": {
            ".read": "auth != null && (root.child('employees').child(auth.uid).child('profile').child('role').val() === 'md' || root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner')",
            "$logId": {
                ".write": false
            }
        },
        "demo": {
            ".read": false,
            ".write": false,
            "sources": {
                ".read": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'",
                ".write": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'"
            },
            "sessions": {
                ".indexOn": [
                    "sourceId",
                    "createdAt",
                    "completed",
                    "startedAt"
                ],
                ".read": "auth != null && root.child('employees').child(auth.uid).child('profile').child('role').val() === 'owner'",
                "$sessionId": {
                    ".write": "auth != null && (!data.exists() || data.child('ownerUid').val() === auth.uid)",
                    "events": {
                        ".write": "auth != null && root.child('demo').child('sessions').child($sessionId).child('ownerUid').val() === auth.uid"
                    }
                }
            }
        }
    }
}